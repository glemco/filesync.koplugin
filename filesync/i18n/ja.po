# Japanese translations for FileSync KOReader plugin
#
msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Language: ja\n"

msgid "FileSync"
msgstr "FileSync"

msgid "FileSync - Wireless File Manager"
msgstr "FileSync - ワイヤレスファイルマネージャー"

msgid "Launches a local HTTP web server and displays a QR code. Scan with your phone to manage books and files on your device wirelessly through a clean web interface."
msgstr "ローカルHTTPウェブサーバーを起動し、QRコードを表示します。スマートフォンでスキャンすると、ウェブインターフェースからデバイス上の書籍やファイルをワイヤレスで管理できます。"

msgid "Stop file server"
msgstr "ファイルサーバーを停止"

msgid "Start file server"
msgstr "ファイルサーバーを起動"

msgid "Server port"
msgstr "サーバーポート"

msgid "Safe mode"
msgstr "セーフモード"

msgid "Show QR code"
msgstr "QRコードを表示"

msgid "About"
msgstr "このプラグインについて"

msgid "FileSync v1.0.0\n\nWireless file manager for KOReader.\n\nStart the server, scan the QR code with your phone, and manage your books from any browser on the same WiFi network."
msgstr "FileSync v1.0.0\n\nKOReader用ワイヤレスファイルマネージャー。\n\nサーバーを起動し、スマートフォンでQRコードをスキャンして、同じWiFiネットワーク上の任意のブラウザから書籍を管理できます。"

msgid "Cancel"
msgstr "キャンセル"

msgid "Save"
msgstr "保存"

msgid "Port set to %1. Restart the server for changes to take effect."
msgstr "ポートを%1に設定しました。変更を反映するにはサーバーを再起動してください。"

msgid "Invalid port. Please enter a number between 1024 and 65535."
msgstr "無効なポートです。1024から65535の間の数値を入力してください。"

msgid "FileSync server is already running."
msgstr "FileSyncサーバーはすでに実行中です。"

msgid "WiFi is not enabled. Please turn on WiFi first."
msgstr "WiFiが有効になっていません。先にWiFiをオンにしてください。"

msgid "Could not determine device IP address. Make sure WiFi is connected."
msgstr "デバイスのIPアドレスを取得できませんでした。WiFiが接続されていることを確認してください。"

msgid "Failed to start server: %1"
msgstr "サーバーの起動に失敗しました: %1"

msgid "FileSync server stopped."
msgstr "FileSyncサーバーが停止しました。"

msgid "Low Battery"
msgstr "バッテリー残量低下"

msgid "Battery level is at %1%. Running the server may drain the battery quickly."
msgstr "バッテリー残量は%1%です。サーバーを実行するとバッテリーが急速に消耗する可能性があります。"

msgid "Start Anyway"
msgstr "それでも起動"

msgid "Server is not running."
msgstr "サーバーは実行されていません。"

msgid "Scan the QR code or enter the URL\nin your browser.\n\nBoth devices must be on the same WiFi network."
msgstr "QRコードをスキャンするか、URLを\nブラウザに入力してください。\n\n両方のデバイスが同じWiFiネットワークに接続されている必要があります。"

msgid "Stop Server"
msgstr "サーバーを停止"

msgid "Server running in the background. Stop the server to save battery."
msgstr "サーバーがバックグラウンドで実行中です。バッテリーを節約するにはサーバーを停止してください。"

msgid "Image preview"
msgstr "画像プレビュー"

