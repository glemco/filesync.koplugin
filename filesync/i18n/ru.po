# Russian translations for FileSync KOReader plugin
#
msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Language: ru\n"

msgid "FileSync"
msgstr "FileSync"

msgid "FileSync - Wireless File Manager"
msgstr "FileSync - Беспроводной файловый менеджер"

msgid "Launches a local HTTP web server and displays a QR code. Scan with your phone to manage books and files on your device wirelessly through a clean web interface."
msgstr "Запускает локальный HTTP веб-сервер и отображает QR-код. Отсканируйте его телефоном, чтобы управлять книгами и файлами на устройстве по беспроводной сети через удобный веб-интерфейс."

msgid "Stop file server"
msgstr "Остановить файловый сервер"

msgid "Start file server"
msgstr "Запустить файловый сервер"

msgid "Server port"
msgstr "Порт сервера"

msgid "Safe mode"
msgstr "Безопасный режим"

msgid "Show QR code"
msgstr "Показать QR-код"

msgid "About"
msgstr "О плагине"

msgid "FileSync v1.0.0\n\nWireless file manager for KOReader.\n\nStart the server, scan the QR code with your phone, and manage your books from any browser on the same WiFi network."
msgstr "FileSync v1.0.0\n\nБеспроводной файловый менеджер для KOReader.\n\nЗапустите сервер, отсканируйте QR-код телефоном и управляйте книгами из любого браузера в той же сети WiFi."

msgid "Cancel"
msgstr "Отмена"

msgid "Save"
msgstr "Сохранить"

msgid "Port set to %1. Restart the server for changes to take effect."
msgstr "Порт установлен на %1. Перезапустите сервер, чтобы изменения вступили в силу."

msgid "Invalid port. Please enter a number between 1024 and 65535."
msgstr "Недопустимый порт. Введите число от 1024 до 65535."

msgid "FileSync server is already running."
msgstr "Сервер FileSync уже запущен."

msgid "WiFi is not enabled. Please turn on WiFi first."
msgstr "WiFi не включён. Сначала включите WiFi."

msgid "Could not determine device IP address. Make sure WiFi is connected."
msgstr "Не удалось определить IP-адрес устройства. Убедитесь, что WiFi подключён."

msgid "Failed to start server: %1"
msgstr "Не удалось запустить сервер: %1"

msgid "FileSync server stopped."
msgstr "Сервер FileSync остановлен."

msgid "Low Battery"
msgstr "Низкий заряд батареи"

msgid "Battery level is at %1%. Running the server may drain the battery quickly."
msgstr "Уровень заряда батареи: %1%. Работа сервера может быстро разрядить батарею."

msgid "Start Anyway"
msgstr "Всё равно запустить"

msgid "Server is not running."
msgstr "Сервер не запущен."

msgid "Scan the QR code or enter the URL\nin your browser.\n\nBoth devices must be on the same WiFi network."
msgstr "Отсканируйте QR-код или введите URL\nв браузере.\n\nОба устройства должны быть в одной сети WiFi."

msgid "Stop Server"
msgstr "Остановить сервер"

msgid "Server running in the background. Stop the server to save battery."
msgstr "Сервер работает в фоновом режиме. Остановите сервер для экономии батареи."

msgid "Image preview"
msgstr "Предпросмотр изображения"

