# French translations for FileSync KOReader plugin
#
msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Language: fr\n"

msgid "FileSync"
msgstr "FileSync"

msgid "FileSync - Wireless File Manager"
msgstr "FileSync - Gestionnaire de fichiers sans fil"

msgid "Launches a local HTTP web server and displays a QR code. Scan with your phone to manage books and files on your device wirelessly through a clean web interface."
msgstr "Lance un serveur web HTTP local et affiche un code QR. Scannez-le avec votre téléphone pour gérer vos livres et fichiers sur votre appareil sans fil via une interface web épurée."

msgid "Stop file server"
msgstr "Arrêter le serveur de fichiers"

msgid "Start file server"
msgstr "Démarrer le serveur de fichiers"

msgid "Server port"
msgstr "Port du serveur"

msgid "Safe mode"
msgstr "Mode sécurisé"

msgid "Show QR code"
msgstr "Afficher le code QR"

msgid "About"
msgstr "À propos"

msgid "FileSync v1.0.0\n\nWireless file manager for KOReader.\n\nStart the server, scan the QR code with your phone, and manage your books from any browser on the same WiFi network."
msgstr "FileSync v1.0.0\n\nGestionnaire de fichiers sans fil pour KOReader.\n\nDémarrez le serveur, scannez le code QR avec votre téléphone et gérez vos livres depuis n'importe quel navigateur sur le même réseau WiFi."

msgid "Cancel"
msgstr "Annuler"

msgid "Save"
msgstr "Enregistrer"

msgid "Port set to %1. Restart the server for changes to take effect."
msgstr "Port défini sur %1. Redémarrez le serveur pour appliquer les modifications."

msgid "Invalid port. Please enter a number between 1024 and 65535."
msgstr "Port non valide. Veuillez entrer un nombre entre 1024 et 65535."

msgid "FileSync server is already running."
msgstr "Le serveur FileSync est déjà en cours d'exécution."

msgid "WiFi is not enabled. Please turn on WiFi first."
msgstr "Le WiFi n'est pas activé. Veuillez d'abord activer le WiFi."

msgid "Could not determine device IP address. Make sure WiFi is connected."
msgstr "Impossible de déterminer l'adresse IP de l'appareil. Vérifiez que le WiFi est connecté."

msgid "Failed to start server: %1"
msgstr "Échec du démarrage du serveur : %1"

msgid "FileSync server stopped."
msgstr "Serveur FileSync arrêté."

msgid "Low Battery"
msgstr "Batterie faible"

msgid "Battery level is at %1%. Running the server may drain the battery quickly."
msgstr "Le niveau de batterie est à %1%. L'exécution du serveur peut vider la batterie rapidement."

msgid "Start Anyway"
msgstr "Démarrer quand même"

msgid "Server is not running."
msgstr "Le serveur n'est pas en cours d'exécution."

msgid "Scan the QR code or enter the URL\nin your browser.\n\nBoth devices must be on the same WiFi network."
msgstr "Scannez le code QR ou saisissez l'URL\ndans votre navigateur.\n\nLes deux appareils doivent être sur le même réseau WiFi."

msgid "Stop Server"
msgstr "Arrêter le serveur"

msgid "Server running in the background. Stop the server to save battery."
msgstr "Serveur en cours d'exécution en arrière-plan. Arrêtez le serveur pour économiser la batterie."

msgid "Image preview"
msgstr "Aperçu de l'image"

